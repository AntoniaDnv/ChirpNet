@model ChirpNet.Services.Data.Admin.AdminDashboardServiceModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="page-title mb-1">Admin Dashboard</h1>
        <p class="page-subtitle mb-0">
            Overview of ChirpNet activity and moderation tools.
        </p>
    </div>

    <a asp-area="Admin"
       asp-controller="Posts"
       asp-action="Index"
       class="btn btn-primary">
        Manage Posts
    </a>
</div>

<div class="row g-3">
    <div class="col-12 col-md-4">
        <div class="stat-card">
            <h2 class="h5 text-muted">Users</h2>
            <p class="display-5 mb-0">@Model.UsersCount</p>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="stat-card">
            <h2 class="h5 text-muted">Posts</h2>
            <p class="display-5 mb-0">@Model.PostsCount</p>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="stat-card">
            <h2 class="h5 text-muted">Comments</h2>
            <p class="display-5 mb-0">@Model.CommentsCount</p>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="stat-card">
            <h2 class="h5 text-muted">Likes</h2>
            <p class="display-5 mb-0">@Model.LikesCount</p>
        </div>
    </div>

    <div class="col-12 col-md-4">
        <div class="stat-card">
            <h2 class="h5 text-muted">Follows</h2>
            <p class="display-5 mb-0">@Model.FollowsCount</p>
        </div>
    </div>
</div>