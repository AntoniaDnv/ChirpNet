@model IEnumerable<ChirpNet.Services.Data.Admin.AdminPostServiceModel>

@{
    ViewData["Title"] = "Manage Posts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Manage Posts</h1>

    <a asp-area="Admin"
       asp-controller="Dashboard"
       asp-action="Index"
       class="btn btn-outline-secondary">
        Back to Dashboard
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No posts found.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Content</th>
                    <th>Author</th>
                    <th>Created</th>
                    <th>Stats</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model)
                {
                    <tr>
                        <td>@post.Id</td>
                        <td style="max-width: 350px;">
                            @post.Content
                        </td>
                        <td>@post.AuthorDisplayName</td>
                        <td>@post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            ❤ @post.LikesCount
                            <br />
                            💬 @post.CommentsCount
                        </td>
                        <td>
                            @if (post.IsDeleted)
                            {
                                <span class="badge bg-danger">Deleted</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-area=""
                               asp-controller="Posts"
                               asp-action="Details"
                               asp-route-id="@post.Id"
                               class="btn btn-sm btn-outline-secondary">
                                View
                            </a>

                            @if (post.IsDeleted)
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="Restore"
                                      asp-route-id="@post.Id"
                                      method="post"
                                      class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        Restore
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Admin"
                                      asp-controller="Posts"
                                      asp-action="Delete"
                                      asp-route-id="@post.Id"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Delete this post as admin?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}