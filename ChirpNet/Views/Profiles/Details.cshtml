@model ChirpNet.Services.Data.Models.Profiles.ProfileDetailsServiceModel

@{
    ViewData["Title"] = $"{Model.DisplayName}'s Profile";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <section class="section-card mb-4">
            <div class="d-flex flex-column flex-md-row align-items-md-center gap-4">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl"
                         alt="@Model.DisplayName profile image"
                         class="rounded-circle"
                         width="96"
                         height="96" />
                }
                else
                {
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                         style="width:96px;height:96px;font-size:2.5rem;">
                        @Model.DisplayName[0]
                    </div>
                }

                <div class="flex-grow-1">
                    <h1 class="page-title mb-1">@Model.DisplayName</h1>
                    <p class="page-subtitle mb-0">
                        Joined @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")
                    </p>

                    @if (!string.IsNullOrWhiteSpace(Model.Bio))
                    {
                        <p class="mt-3 mb-0">@Model.Bio</p>
                    }
                </div>

                @if (User.Identity?.IsAuthenticated == true && !Model.IsCurrentUserProfile)
                {
                    if (Model.IsFollowedByCurrentUser)
                    {
                        <form asp-controller="Profiles"
                              asp-action="Unfollow"
                              asp-route-id="@Model.UserId"
                              method="post">
                            <button type="submit" class="btn btn-outline-secondary">
                                Unfollow
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Profiles"
                              asp-action="Follow"
                              asp-route-id="@Model.UserId"
                              method="post">
                            <button type="submit" class="btn btn-primary">
                                Follow
                            </button>
                        </form>
                    }
                }
            </div>

            <div class="row g-3 mt-4">
                <div class="col-12 col-md-4">
                    <div class="stat-card text-center">
                        <h2 class="h3">@Model.PostsCount</h2>
                        <p class="text-muted mb-0">Posts</p>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="stat-card text-center">
                        <h2 class="h3">@Model.FollowersCount</h2>
                        <p class="text-muted mb-0">Followers</p>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="stat-card text-center">
                        <h2 class="h3">@Model.FollowingCount</h2>
                        <p class="text-muted mb-0">Following</p>
                    </div>
                </div>
            </div>
        </section>

        <h2 class="h4 mb-3">Recent Posts</h2>

        @if (!Model.RecentPosts.Any())
        {
            <div class="empty-state">
                This user has not posted anything yet.
            </div>
        }
        else
        {
            foreach (var post in Model.RecentPosts)
            {
                <article class="post-card p-4 mb-3">
                    <p class="fs-5">@post.Content</p>

                    <div class="d-flex flex-wrap gap-3 post-meta mb-3">
                        <span>@post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        <span>❤ @post.LikesCount likes</span>
                        <span>💬 @post.CommentsCount comments</span>
                    </div>

                    <a asp-controller="Posts"
                       asp-action="Details"
                       asp-route-id="@post.Id"
                       class="btn btn-sm btn-outline-primary">
                        View Details
                    </a>
                </article>
            }
        }
    </div>
</div>