@model IEnumerable<ChirpNet.Services.Data.Models.Profiles.ProfilePostServiceModel>

@{
    ViewData["Title"] = "My Posts";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="page-title mb-1">My Posts</h1>
                <p class="page-subtitle mb-0">
                    Manage the posts you have shared on ChirpNet.
                </p>
            </div>

            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                + Create Post
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h2 class="h5">You have not posted yet</h2>
                <p class="mb-3">Create your first post and it will appear here.</p>

                <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                    Create Post
                </a>
            </div>
        }
        else
        {
            foreach (var post in Model)
            {
                <article class="post-card p-4 mb-3">
                    <p class="fs-5">@post.Content</p>

                    <div class="d-flex flex-wrap gap-3 post-meta mb-3">
                        <span>@post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")</span>
                        <span>❤ @post.LikesCount likes</span>
                        <span>💬 @post.CommentsCount comments</span>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a asp-controller="Posts"
                           asp-action="Details"
                           asp-route-id="@post.Id"
                           class="btn btn-sm btn-outline-secondary">
                            Details
                        </a>

                        <a asp-controller="Posts"
                           asp-action="Edit"
                           asp-route-id="@post.Id"
                           class="btn btn-sm btn-outline-primary">
                            Edit
                        </a>

                        <form asp-controller="Posts"
                              asp-action="Delete"
                              asp-route-id="@post.Id"
                              method="post"
                              onsubmit="return confirm('Are you sure you want to delete this post?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Delete
                            </button>
                        </form>
                    </div>
                </article>
            }
        }
    </div>
</div>