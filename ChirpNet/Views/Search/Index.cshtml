@model ChirpNet.Services.Data.Models.Search.SearchResultsServiceModel

@{
    ViewData["Title"] = "Search";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-9">
        <h1 class="h3 mb-4">Search</h1>

        <form asp-controller="Search" asp-action="Index" method="get" class="mb-4">
            <div class="input-group">
                <input type="text"
                       name="keyword"
                       value="@Model.Keyword"
                       class="form-control"
                       placeholder="Search posts or users..." />

                <button type="submit" class="btn btn-primary">
                    Search
                </button>
            </div>
        </form>

        @if (string.IsNullOrWhiteSpace(Model.Keyword))
        {
            <div class="alert alert-info">
                Type a keyword to search for posts and users.
            </div>
        }
        else
        {
            <div class="mb-5">
                <h2 class="h5 mb-3">Users</h2>

                @if (!Model.Users.Any())
                {
                    <div class="alert alert-light border">
                        No users found.
                    </div>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var user in Model.Users)
                        {
                            <a asp-controller="Profiles"
                               asp-action="Details"
                               asp-route-id="@user.Id"
                               class="list-group-item list-group-item-action">
                                <strong>@user.DisplayName</strong>

                                @if (!string.IsNullOrWhiteSpace(user.Bio))
                                {
                                    <div class="text-muted small">
                                        @user.Bio
                                    </div>
                                }
                            </a>
                        }
                    </div>
                }
            </div>

            <div>
                <h2 class="h5 mb-3">Posts</h2>

                @if (!Model.Posts.Any())
                {
                    <div class="alert alert-light border">
                        No posts found.
                    </div>
                }
                else
                {
                    foreach (var post in Model.Posts)
                    {
                        <article class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <a asp-controller="Profiles"
                                       asp-action="Details"
                                       asp-route-id="@post.AuthorId"
                                       class="fw-bold text-decoration-none">
                                        @post.AuthorDisplayName
                                    </a>

                                    <small class="text-muted">
                                        @post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                    </small>
                                </div>

                                <p class="mt-3">@post.Content</p>

                                <a asp-controller="Posts"
                                   asp-action="Details"
                                   asp-route-id="@post.Id"
                                   class="btn btn-sm btn-outline-secondary">
                                    Details
                                </a>
                            </div>
                        </article>
                    }
                }
            </div>
        }
    </div>
</div>