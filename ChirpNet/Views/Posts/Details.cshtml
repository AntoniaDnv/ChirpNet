@using Microsoft.AspNetCore.Identity
@using ChirpNet.Data.Data.Models
@using System.Security.Claims
@model ChirpNet.Services.Data.Models.Posts.PostDetailsServiceModel

@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Post Details";
}
<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">
        <a asp-controller="Posts" asp-action="Feed" class="btn btn-outline-secondary btn-sm mb-3">
            Back to Feed
        </a>

        <article class="card mb-4 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <a asp-controller="Profiles"
                       asp-action="Details"
                       asp-route-id="@Model.AuthorId"
                       class="fw-bold text-decoration-none">
                        @Model.AuthorDisplayName
                    </a>
                    <small class="text-muted">
                        @Model.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </small>
                </div>

                <p class="mt-3 mb-3">
                    @Model.Content
                </p>

                <div class="d-flex align-items-center gap-2 text-muted small">
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            id="likeButton"
                            data-post-id="@Model.Id">
                        ❤ Like
                    </button>

                    <span id="likesCount">@Model.LikesCount</span>
                    <span>likes</span>
                </div>
                @if (User.Identity?.IsAuthenticated == true &&
                User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.AuthorId)
{
                    <div class="mt-3 d-flex gap-2">
                        <a asp-controller="Posts"
                           asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-sm btn-outline-primary">
                            Edit
                        </a>

                        <form asp-controller="Posts"
                              asp-action="Delete"
                              asp-route-id="@Model.Id"
                              method="post"
                              onsubmit="return confirm('Are you sure you want to delete this post?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Delete
                            </button>
                        </form>
                    </div>
                }
            </div>
        </article>

        <section class="mb-4">
            <h2 class="h5 mb-3">Comments</h2>

            @if (!Model.Comments.Any())
            {
                <div class="alert alert-info">
                    No comments yet. Be the first to comment.
                </div>
            }
            else
            {
                foreach (var comment in Model.Comments)
                {
                    <div class="card mb-2">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <strong>@comment.AuthorDisplayName</strong>
                                <small class="text-muted">
                                    @comment.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                                </small>
                            </div>

                            <p class="mb-0 mt-2">
                                @comment.Content
                            </p>
                        </div>
                    </div>
                }
            }
        </section>

        <section class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Add a comment</h2>

                @if (SignInManager.IsSignedIn(User))
                {
                    <form asp-controller="Posts" asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PostId" value="@Model.Id" />

                        <div class="mb-3">
                            <label for="Content" class="form-label">Content</label>

                            <textarea name="Content"
                                      id="Content"
                                      class="form-control"
                                      rows="3"
                                      maxlength="300"
                                      required
                                      placeholder="Write a comment..."></textarea>

                            <div class="form-text">Maximum 300 characters.</div>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Comment
                        </button>
                    </form>
                }
                else
                {
                    <p class="mb-0">
                        <a asp-area="Identity" asp-page="/Account/Login">Log in</a>
                        to add a comment.
                    </p>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const likeButton = document.getElementById('likeButton');

        if (likeButton) {
            likeButton.addEventListener('click', async function () {
                const postId = this.dataset.postId;

                const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
                const token = tokenInput ? tokenInput.value : '';

                const response = await fetch(`/api/likes/toggle/${postId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token
                    }
                });

                if (response.status === 401) {
                    window.location.href = '/Identity/Account/Login';
                    return;
                }

                if (!response.ok) {
                    alert('Something went wrong while liking the post.');
                    return;
                }

                const data = await response.json();

                document.getElementById('likesCount').textContent = data.likesCount;
                likeButton.textContent = data.isLiked ? '❤ Unlike' : '❤ Like';
            });
        }
    </script>
}