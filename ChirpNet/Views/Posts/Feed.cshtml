@model IEnumerable<ChirpNet.Services.Data.Models.Posts.PostFeedServiceModel>

@{
    ViewData["Title"] = "Public Feed";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="page-title mb-1">Public Feed</h1>
                <p class="page-subtitle mb-0">
                    See what the ChirpNet community is sharing.
                </p>
            </div>

            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                + Create Post
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h2 class="h5">No posts yet</h2>
                <p class="mb-3">Be the first to share something with the community.</p>

                <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                    Create First Post
                </a>
            </div>
        }
        else
        {
            foreach (var post in Model)
            {
                <article class="post-card p-4 mb-3">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <a asp-controller="Profiles"
                           asp-action="Details"
                           asp-route-id="@post.AuthorId"
                           class="fw-bold text-primary">
                            @post.AuthorDisplayName
                        </a>

                        <small class="post-meta text-nowrap">
                            @post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                        </small>
                    </div>

                    <p class="mt-3 mb-3 fs-5">
                        @post.Content
                    </p>

                    <div class="d-flex flex-wrap gap-3 post-meta mb-3">
                        <span>❤ @post.LikesCount likes</span>
                        <span>💬 @post.CommentsCount comments</span>
                    </div>

                    <a asp-controller="Posts"
                       asp-action="Details"
                       asp-route-id="@post.Id"
                       class="btn btn-sm btn-outline-primary">
                        View Details
                    </a>
                </article>
            }
        }
    </div>
</div>