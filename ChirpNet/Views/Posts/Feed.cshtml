@model IEnumerable<ChirpNet.Services.Data.Models.Posts.PostFeedServiceModel>

@{
    ViewData["Title"] = "Public Feed";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Public Feed</h1>

            <a asp-controller="Posts" asp-action="Create" class="btn btn-primary">
                Create Post
            </a>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                No posts yet. Be the first to post something!
            </div>
        }
        else
        {
            foreach (var post in Model)
            {
                <article class="card mb-3 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <strong>@post.AuthorDisplayName</strong>
                            <small class="text-muted">
                                @post.CreatedOn.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                            </small>
                        </div>

                        <p class="mt-3 mb-3">
                            @post.Content
                        </p>

                        <div class="d-flex gap-3 text-muted small">
                            <span>❤ @post.LikesCount likes</span>
                            <span>💬 @post.CommentsCount comments</span>
                        </div>

                        <div class="mt-3">
                            <a asp-controller="Posts"
                               asp-action="Details"
                               asp-route-id="@post.Id"
                               class="btn btn-sm btn-outline-secondary">
                                Details
                            </a>
                        </div>
                    </div>
                </article>
            }
        }
    </div>
</div>